.venv*/
__pycache__/
*.pyc
.cache/
.DS_Store
.env

# Local ROCm wheel cache (large binaries, do not commit)
rocm-wheels/

# Local logs / captures
*.log

# Medical data (never commit raw medical data or derived datasets)
data/

# Common medical imaging formats (raw)
*.dcm
*.dicom
*.nii
*.nii.gz
*.mhd
*.nrrd

# Derived images (scoped to data folder only)
data/**/*.png
data/**/*.jpg
data/**/*.jpeg

# Training runs and checkpoints
runs/
checkpoints/
